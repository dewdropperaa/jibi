<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/md_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvBudgetCardCategory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/md_on_background"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSetBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Définir plafond ✏️"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:padding="6dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvBudgetCardSpent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/md_on_surface"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <ProgressBar
            android:id="@+id/progressBudgetCard"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/md_primary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
